{
	"name": "CompilerGym",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"postCreateCommand": "echo 'Conda Environment Ready'",
	"customizations": {
		"vscode": {
		  "extensions": [
			"ms-python.python",
			"ms-python.vscode-pylance"
		  ],
		  "settings": {
			"terminal.integrated.defaultProfile.linux": "bash",
			"python.defaultInterpreterPath": "/opt/conda/envs/comgym/bin/python",
			"python.linting.enabled": true,
			"python.linting.pylintEnabled": true,
			"extensions.verifySignature": false
			}
		}
	}
}